---
interface Props {
  title: string;
  promise: string;
  index?: number;
}

const { title, promise, index = 0 } = Astro.props;
const moduleNumber = index + 1;
---

<article class="card" data-animate-child style={`--reveal-delay: ${index * 60}ms`}>
  <p class="text-small font-semibold text-amber">Module {moduleNumber}</p>
  <h3 class="card-title mt-2 text-navy">{title}</h3>
  <p class="mt-3 text-charcoal">{promise}</p>
</article>
