---
interface Props {
  title: string;
  promise: string;
  index?: number;
}

const { title, promise, index = 0 } = Astro.props;
---

<article class="card" data-reveal style={`--reveal-delay: ${index * 60}ms`}>
  <h3 class="text-navy">{title}</h3>
  <p class="mt-3 text-charcoal">{promise}</p>
</article>
