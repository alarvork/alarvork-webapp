---
interface Props {
  title: string;
  summary: string;
  bullets: string[];
  deliverable: string;
  index?: number;
}

const { title, summary, bullets, deliverable, index = 0 } = Astro.props;
---

<article class="card" data-reveal style={`--reveal-delay: ${index * 60}ms`}>
  <h3 class="text-navy">{title}</h3>
  <p class="mt-3 text-charcoal">{summary}</p>
  <ul class="mt-4 list-disc space-y-2 pl-5 text-charcoal">
    {bullets.map((bullet) => <li>{bullet}</li>)}
  </ul>
  <p class="mt-4 text-small text-pewter">
    <span class="font-semibold text-navy">Deliverable:</span> {deliverable}
  </p>
</article>
