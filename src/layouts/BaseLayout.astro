---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CtaBand from '../components/CtaBand.astro';
import { SITE_URL, GA_ID, EMAIL, LINKEDIN } from '../consts';

interface Props {
  title: string;
  description: string;
  path: string;
  ctaHeadline?: string;
  showCta?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  path,
  ctaHeadline = 'Ready to build the machine that sells?',
  showCta = true,
  jsonLd,
} = Astro.props;

const canonical = new URL(path, SITE_URL).href;
const ogImage = new URL('/images/og-default.jpg', SITE_URL).href;

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Alar Võrk',
  jobTitle: 'Sales Architect',
  url: SITE_URL,
  email: EMAIL,
  sameAs: [LINKEDIN],
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'Abacto Consulting',
  url: SITE_URL,
  email: EMAIL,
};

const extraSchemas = jsonLd
  ? Array.isArray(jsonLd)
    ? jsonLd
    : [jsonLd]
  : [];

const schemas = [personSchema, serviceSchema, ...extraSchemas];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index,follow" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {
      schemas.map((schema) => (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
      ))
    }
  </head>
  <body>
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:rounded-lg focus:bg-amber focus:px-4 focus:py-2 focus:text-white"
    >
      Skip to content
    </a>

    <Header />
    <main id="main-content">
      <slot />
      {showCta && <CtaBand headline={ctaHeadline} />}
    </main>
    <Footer />

    <div
      id="cookie-consent"
      class="fixed inset-x-0 bottom-0 z-[60] hidden border-t border-pewter/20 bg-white p-4 shadow-lg md:p-5"
      role="dialog"
      aria-label="Cookie consent"
      aria-live="polite"
    >
      <div class="container-page flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
        <p class="text-small text-charcoal">
          We use cookies to understand how visitors use this site. You can accept analytics
          cookies or decline.
        </p>
        <div class="flex shrink-0 gap-3">
          <button
            type="button"
            id="cookie-decline"
            class="rounded-lg border border-pewter px-4 py-2 text-sm font-semibold text-pewter hover:border-charcoal hover:text-charcoal"
          >
            Decline
          </button>
          <button
            type="button"
            id="cookie-accept"
            class="rounded-lg bg-amber px-4 py-2 text-sm font-semibold text-white hover:bg-amber-dark"
          >
            Accept
          </button>
        </div>
      </div>
    </div>

    <script define:vars={{ gaId: GA_ID }}>
      const CONSENT_KEY = 'alarvork-cookie-consent';
      const banner = document.getElementById('cookie-consent');
      const acceptBtn = document.getElementById('cookie-accept');
      const declineBtn = document.getElementById('cookie-decline');

      function loadGa() {
        if (!gaId || gaId === 'G-REPLACE_ME') return;

        const script = document.createElement('script');
        script.async = true;
        script.src = `https://www.googletagmanager.com/gtag/js?id=${gaId}`;
        document.head.appendChild(script);

        window.dataLayer = window.dataLayer || [];
        function gtag() {
          window.dataLayer.push(arguments);
        }
        window.gtag = gtag;
        gtag('js', new Date());
        gtag('config', gaId);
      }

      const stored = localStorage.getItem(CONSENT_KEY);

      if (stored === 'accepted') {
        loadGa();
      } else if (stored !== 'declined' && banner) {
        banner.classList.remove('hidden');
      }

      acceptBtn?.addEventListener('click', () => {
        localStorage.setItem(CONSENT_KEY, 'accepted');
        banner?.classList.add('hidden');
        loadGa();
      });

      declineBtn?.addEventListener('click', () => {
        localStorage.setItem(CONSENT_KEY, 'declined');
        banner?.classList.add('hidden');
      });
    </script>

    <script>
      import '../scripts/motion.js';
    </script>
  </body>
</html>
