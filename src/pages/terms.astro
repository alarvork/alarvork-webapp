---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import LegalProse from '../components/LegalProse.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('legal', 'terms-and-conditions');
if (!entry) {
  throw new Error('Terms and conditions not found in docs/legal/');
}

const { Content } = await render(entry);
---

<BaseLayout
  title="Terms & Conditions | Alar Võrk — Sales Architect"
  description="Terms and conditions for using alarvork.com, operated by Abacto Consulting OÜ."
  path="/terms"
  showCta={false}
>
  <Section class="!py-16 md:!py-24">
    <div data-animate-child>
      <LegalProse>
        <Content />
      </LegalProse>
    </div>
  </Section>
</BaseLayout>
